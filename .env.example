# Word metadata: set to 1 or true to skip all persist (for testing)
# VITE_WORD_METADATA_DRY_RUN=1

# OpenAI API key (same as SmartSubs: VITE_OPENAI_API_KEY in .env)
VITE_OPENAI_API_KEY=sk-...
VITE_SUPABASE_URL=https://vuxeemwxdldfjybzgtxc.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_DB_PASSWORD=your-db-password
# Optional: full connection string from Supabase Dashboard > Settings > Database (use if migrate script fails)
# DATABASE_URL=postgresql://postgres.[PROJECT]:[PASSWORD]@aws-0-[REGION].pooler.supabase.com:5432/postgres

# Cloudflare R2 (for media uploads)
# Account Id - from dashboard
CLOUDFLARE_ACCOUNT_ID=
# S3 API - Access Key ID and Secret Access Key from R2 > Manage R2 API Tokens
CLOUDFLARE_S3_ACCESS_KEY_ID=
CLOUDFLARE_S3_SECRET_ACCESS_KEY=
# Bucket name and public URL (e.g. https://pub-xxx.r2.dev) - also set as Supabase secrets
CLOUDFLARE_R2_BUCKET_NAME=
CLOUDFLARE_R2_PUBLIC_URL=
